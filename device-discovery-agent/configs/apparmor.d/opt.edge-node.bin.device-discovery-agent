include <tunables/global>


/opt/edge-node/bin/device-discovery-agent {
  include <abstractions/base>
  include <abstractions/nameservice>

  capability dac_read_search,
  capability net_admin,
  capability sys_admin,
  capability sys_resource,

  network inet dgram,
  network inet stream,
  network inet6 dgram,
  network inet6 stream,
  network unix dgram,
  network unix stream,

  deny /boot/** rw,
  deny /proc/kcore rw,
  deny /sys/kernel/security/** rw,

  /dev/mem r,
  /dev/shm/idp_access_token rw,
  /dev/shm/release_token rw,
  /etc/edge-node/node/confs/device-discovery-agent.env r,
  /etc/hosts r,
  /etc/intel_edge_node/orch-ca-cert/orch-ca.pem r,
  /etc/nsswitch.conf r,
  /etc/resolv.conf r,
  /etc/ssl/certs/** r,
  /etc/ssl/openssl.cnf r,
  /opt/edge-node/bin/device-discovery-agent mr,
  /proc/cmdline r,
  /proc/cmdline r,
  /proc/sys/kernel/hostname r,
  /proc/sys/net/core/somaxconn r,
  /sys/class/dmi/id/board_serial r,
  /sys/class/dmi/id/product_serial r,
  /sys/class/dmi/id/product_uuid r,
  /sys/class/net/*/address r,
  /sys/class/net/*/operstate r,
  /sys/devices/** r,
  /sys/firmware/dmi/tables/DMI r,
  /sys/firmware/dmi/tables/smbios_entry_point r,
  /sys/kernel/mm/transparent_hugepage/hpage_pmd_size r,
  /tmp/** rw,
  /usr/bin/ip rix,
  /usr/bin/lshw rix,
  /usr/bin/sudo rPx -> dda_sudo,
  /usr/sbin/ip rix,
  /usr/sbin/lshw rix,
  /usr/share/ca-certificates/** r,
  /etc/edge-node/node/confs/ rw,
  /etc/edge-node/node/confs/** rw,
  /etc/intel_edge_node/client-credentials/ rw,
  /etc/intel_edge_node/client-credentials/** rw,
  owner /etc/intel_edge_node/client-credentials/client_id rw,
  owner /etc/intel_edge_node/client-credentials/client_secret rw,
  owner /etc/intel_edge_node/client-credentials/project_id rw,
  owner /proc/*/mountinfo r,
  owner /tmp/** rw,

}

profile dda_sudo {
  include <abstractions/base>
  include <abstractions/consoles>
  include <abstractions/nameservice>

  capability audit_write,
  capability setgid,
  capability setuid,
  capability sys_resource,

  /etc/locale.conf r,
  /etc/security/limits.d/* r,
  /etc/sudoers r,
  /etc/sudoers.d/* r,
  /proc/*/loginuid r,
  /proc/sys/kernel/seccomp/actions_avail r,
  /run/systemd/resolve/stub-resolv.conf r,
  /usr/bin/sudo mr,
  /usr/libexec/sudo/libsudo_util.so.* mr,
  /usr/libexec/sudo/audit_json.so mr,
  /usr/sbin/dmidecode rPx -> dda_dmidecode,
  owner /etc/default/locale r,
  owner /etc/environment r,
  owner /etc/group r,
  owner /etc/host.conf r,
  owner /etc/hosts r,
  owner /etc/ld.so.cache r,
  owner /etc/locale.alias r,
  owner /etc/login.defs r,
  owner /etc/nsswitch.conf r,
  owner /etc/pam.d/* r,
  owner /etc/passwd r,
  owner /etc/security/capability.conf r,
  owner /etc/security/limits.conf r,
  owner /etc/security/limits.d/ r,
  owner /etc/security/pam_env.conf r,
  owner /etc/shadow r,
  owner /etc/sudo.conf r,
  owner /etc/sudoers.d/ r,
  owner /proc/*/cgroup r,
  owner /proc/*/limits r,
  owner /proc/*/mountinfo r,
  owner /proc/*/stat r,
  owner /proc/filesystems r,
  owner /proc/sys/kernel/ngroups_max r,
  owner /usr/libexec/sudo/sudoers.so mr,

}

profile dda_dmidecode {
  include <abstractions/base>

  /usr/sbin/dmidecode mr,
  owner /dev/mem r,
  owner /sys/firmware/dmi/tables/DMI r,
  owner /sys/firmware/dmi/tables/smbios_entry_point r,
  owner /sys/firmware/efi/systab r,

}
