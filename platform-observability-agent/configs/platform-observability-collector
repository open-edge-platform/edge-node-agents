# Wait for access token
while true
do
	if [ -f /etc/intel_edge_node/tokens/platform-observability-agent/access_token ]; then
	        echo "Starting Platform Observability Collector Service"
		break
	else
		echo "Waiting for token"
        	sleep 10
	fi
done

# Resolve TENANT_ID from available sources
# Priority: systemd-loaded cloud-init tenantId > client-credentials project_id > fail-fast

# If TENANT_ID is not provided by systemd EnvironmentFile, try project_id fallback
if [ -z "$TENANT_ID" ] || [ "$TENANT_ID" = "not-set" ]; then
	if [ -e /etc/intel_edge_node/client-credentials/project_id ] && [ ! -r /etc/intel_edge_node/client-credentials/project_id ]; then
		echo "ERROR: /etc/intel_edge_node/client-credentials/project_id exists but is not readable by $(id -un). Check file ownership and permissions" >&2
		exit 1
	fi
	if [ -f /etc/intel_edge_node/client-credentials/project_id ]; then
		TENANT_ID=$(head -n1 /etc/intel_edge_node/client-credentials/project_id)
		case "$TENANT_ID" in
			*=*) TENANT_ID=${TENANT_ID#*=} ;;
		esac
	fi
fi

# Fail-fast if TENANT_ID is still empty or "not-set"
if [ -z "$TENANT_ID" ] || [ "$TENANT_ID" = "not-set" ]; then
	echo "ERROR: TENANT_ID is not set. Neither /etc/intel_edge_node/tenantId nor /etc/intel_edge_node/client-credentials/project_id contain a valid tenant ID" >&2
	exit 1
fi

# Export TENANT_ID for the collector process
export TENANT_ID

exec "$@"
